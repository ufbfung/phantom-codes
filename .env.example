# Copy this file to `.env` and fill in. `.env` is gitignored.

# LLM API keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# HuggingFace token (optional today; required for v2 work that downloads
# gated models like Llama or calls HF inference endpoints for medical LLMs).
# Get a Read-access token from https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# GCP — only needed if you run the optional cloud path (README "Data setup
# Option 2"). The default workflow is fully local and these env vars can
# stay unset.
#
# Setup steps if using cloud (one-time):
#   1. gcloud auth application-default login
#      (use the Google account that owns/has admin on your destination bucket)
#   2. Create your destination bucket in your GCP project:
#        gcloud storage buckets create gs://YOUR_BUCKET/ \
#          --project=YOUR_PROJECT --location=US-CENTRAL1 \
#          --uniform-bucket-level-access
#   3. gcloud auth application-default set-quota-project YOUR_PROJECT
#      (otherwise gcsfs will pick the wrong billing project)
#
# Then uncomment and set:
# GCP_PROJECT=YOUR_PROJECT
# DERIVED_DATA_BUCKET=gs://YOUR_BUCKET
