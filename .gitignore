# Python
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Virtual envs
.venv/

# Secrets
.env
.env.local

# Notebooks
.ipynb_checkpoints/

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp

# Claude Code local state + internal-only docs (don't publish)
.claude/
CLAUDE.md
CLAUDE.local.md
BACKLOG.md
NOTES.md
*.private.md

# MIMIC-IV-FHIR derived data — DUA prohibits redistribution.
# Anything that contains MIMIC content stays out of git.
data/mimic/
data/derived/
mimic_*.ndjson*
*MimicCondition*

# Model artifacts (rebuild from configs)
models/checkpoints/
models/metrics/
*.pt
*.bin
*.safetensors
faiss_index/

# ML observability dirs that libraries auto-create.
# Gitignored regardless of whether the library is wired up — defense in
# depth against accidental leaks if a contributor adds wandb/mlflow/etc.
wandb/
mlruns/
lightning_logs/
tensorboard/
runs/

# Results — only aggregated CSVs and the rendered paper PDF are kept.
results/raw/
results/predictions/
results/per_run/

# Synthea — the generator binary (cloned + built locally, regenerable
# via scripts/setup_synthea.sh) and the generated synthetic cohorts
# (regenerable via scripts/generate_synthea_cohort.sh from the seed +
# pinned Synthea SHA in the script). The committed manifest at
# benchmarks/synthetic_v1/manifest.yaml lets reproducers verify they
# regenerated the same cohort byte-for-byte.
tools/synthea/
benchmarks/synthetic_v1/raw/
benchmarks/synthetic_v1/pilot/
benchmarks/synthetic_v1/conditions.ndjson

# LaTeX build artifacts
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.toc
paper/*.fls
paper/*.fdb_latexmk
paper/*.synctex.gz
paper/sections/*.aux
