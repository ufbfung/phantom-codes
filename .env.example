# Copy this file to `.env` and fill in. `.env` is gitignored.

# LLM API keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# GCP — needed for reading MIMIC-IV-FHIR from GCS and writing derived data to your own bucket.
# After credentialed PhysioNet access, link your Google account on physionet.org → Cloud,
# then run: gcloud auth application-default login
GCP_PROJECT=your-gcp-project-id
MIMIC_FHIR_BUCKET=gs://mimic-iv-fhir-2.1.physionet.org
DERIVED_DATA_BUCKET=gs://your-research-bucket/llm-code-recovery
